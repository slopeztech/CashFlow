# CashFlow environment defaults
# Copy this file to .env and adjust values as needed.

# ----------------------------
# Core app runtime
# ----------------------------
SECRET_KEY=change-this-in-production
DEBUG=0
ENABLE_REALTIME=1
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost

# ----------------------------
# Database (choose one strategy)
# ----------------------------
# Strategy A: single URL (recommended)
# DATABASE_URL=postgresql://cashflow:cashflow_password@127.0.0.1:5432/cashflow

# Strategy B: split DB variables
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=
DB_CONN_MAX_AGE=60
DB_SSLMODE=

# ----------------------------
# Reverse proxy / HTTPS
# ----------------------------
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
USE_X_FORWARDED_PROTO=1
USE_X_FORWARDED_HOST=1
USE_X_FORWARDED_PORT=1
WHITENOISE_MANIFEST_STRICT=0

# Test and performance settings
RUN_PERFORMANCE_TESTS=1
PERFORMANCE_MAX_SECONDS=8.0

# Global safeguards for generated volumes
TEST_VOLUME_MIN=1
TEST_VOLUME_MAX=50000
TEST_BATCH_MIN=100
TEST_BATCH_MAX=5000

# Shared bulk insert batch size for heavy tests
TEST_BULK_BATCH_SIZE=1000

# Performance test volumes
TEST_PERF_USERS_COUNT=5000
TEST_PERF_MONTHLY_USERS_COUNT=5000
TEST_PERF_PRODUCTS_COUNT=5000
TEST_PERF_LOW_STOCK_RATIO=10
TEST_PERF_MONTHLY_ENABLED_DAYS_AGO=60

# Web scalability test volumes
TEST_SCALE_USERS_COUNT=5000
TEST_SCALE_MONTHLY_USERS_COUNT=5000
TEST_SCALE_MONTHLY_ENABLED_DAYS_AGO=60
TEST_SCALE_PENDING_REQUESTS_COUNT=3000
TEST_SCALE_CATALOG_PRODUCTS_COUNT=3000
TEST_SCALE_REVIEWS_COUNT=2000
